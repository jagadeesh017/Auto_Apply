{
  "manifest_version": 3,
  "name": "Job Auto Fill",
  "version": "2.0",
  "description": "Autofill job application forms using a predefined user profile.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Auto Fill"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
